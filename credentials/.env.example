# Credenciales del proyecto — copiar a .env y rellenar valores reales
# NUNCA commitear el archivo .env

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google APIs
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Slides
GOOGLE_SLIDES_SCOPE=https://www.googleapis.com/auth/presentations

# Gmail
GMAIL_SCOPE=https://www.googleapis.com/auth/gmail.modify

# Google Calendar
GCAL_SCOPE=https://www.googleapis.com/auth/calendar

# Configuracion general
ENVIRONMENT=development
LOG_LEVEL=INFO
DEFAULT_MODEL=claude-sonnet-4-6
